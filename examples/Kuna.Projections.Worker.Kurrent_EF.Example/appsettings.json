{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Debug"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:HH:mm:ss} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "ApplicationName": "Kuna.Projections.Worker.Test"
    }
  },
  "ConnectionStrings": {
    "PostgreSql": "Host=localhost;Port=5432;Database=orders_projection;Username=postgres;Password=postgres",
    "KurrentDB": "esdb://admin:changeit@localhost:2113?tls=false"
  },
  "OrdersProjection": {
    "Source": "KurrentDB",
    "CatchUpPersistenceStrategy": "ModelCountBatching",
    "LiveProcessingPersistenceStrategy": "TimeBasedBatching",
    "MaxPendingProjectionsCount": 5000,
    "SourceBufferCapacity": 1000000,
    "TransformSinkBufferCapacity": 20000,
    "ReadBufferCapacity": 500000,
    "LiveProcessingFlushDelay": 1000,
    "SkipStateNotFoundFailure": false,
    "InFlightModelCacheMinEntries": 1000000,
    "InFlightModelCacheCapacityMultiplier": 3,
    "EventVersionCheckStrategy": "Consecutive",
    "ModelIdResolutionStrategy": "RequireStreamId",
    "KurrentDB": {
      "Filter": {
        "Kind": "StreamPrefix",
        "Prefixes": [
          "order-"
        ]
      }
    }
  }
}
